# ---------------------------------------------------------------------------
# Y2KASE environment variables
# Copy this file to `.env.local` and fill in real values. Never commit secrets.
# ---------------------------------------------------------------------------

# ── Database ─────────────────────────────────────────────────────────────────
# Neon PostgreSQL — create a free database at https://neon.tech
# Use the "pooled" connection string for the app.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ── Better Auth ───────────────────────────────────────────────────────────────
# Generate a 32+ byte secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=""
# Your deployed URL (no trailing slash). Localhost during dev.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── OAuth — Google ────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com
# Redirect URI: https://YOUR_DOMAIN/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── OAuth — Apple Sign In ─────────────────────────────────────────────────────
# Requires Apple Developer account ($99/yr). Critical for iOS users.
# https://developer.apple.com/account/resources/identifiers/list/serviceId
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Used by the AI image ingestion pipeline (GPT vision) for titles/descriptions.
# https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."
OPENAI_VISION_MODEL="gpt-4o-mini"

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Image hosting + CDN + on-the-fly transforms.
# https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# ── Store presentation ────────────────────────────────────────────────────────
NEXT_PUBLIC_STORE_CURRENCY="USD"
# Multiply the legacy HKD prices by this when importing (≈ 1 HKD = 0.128 USD).
IMPORT_HKD_TO_USD_RATE="0.128"

# ── Scripts ───────────────────────────────────────────────────────────────────
# Path to the legacy SQLite catalog used by the one-time import script.
LEGACY_SQLITE_PATH="../Y2KASE_Shopify/data/mdm_catalog.db"

# ── Stripe (future phase) ─────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# STRIPE_WEBHOOK_SECRET=""
