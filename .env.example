# ---------------------------------------------------------------------------
# Y2KASE environment variables
# Copy this file to `.env.local` and fill in real values. Never commit secrets.
# ---------------------------------------------------------------------------

# ── Database ─────────────────────────────────────────────────────────────────
# Neon PostgreSQL — create a free database at https://neon.tech
# Use the "pooled" connection string for the app.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ── Better Auth ───────────────────────────────────────────────────────────────
# Generate a 32+ byte secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=""
# Auth callback base URL (no trailing slash). Defaults to NEXT_PUBLIC_SITE_URL.
BETTER_AUTH_URL="http://localhost:3000"
# Your deployed URL (no trailing slash). Localhost during dev.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── OAuth — Google ────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com
# Redirect URI: https://YOUR_DOMAIN/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── OAuth — Apple Sign In ─────────────────────────────────────────────────────
# Requires Apple Developer account ($99/yr). Critical for iOS users.
# https://developer.apple.com/account/resources/identifiers/list/serviceId
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Used by the AI image ingestion pipeline (GPT vision) for titles/descriptions,
# and by the Social Studio for marketing-image + caption generation.
# https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."
# Vision model for analysing product photos (titles/descriptions/style tags).
# Served via an OpenAI-compatible endpoint. Leave VISION_BASE_URL blank to use
# OpenAI directly; set it (e.g. OpenRouter) to use another provider/model.
VISION_BASE_URL="https://openrouter.ai/api/v1"
VISION_API_KEY="sk-or-v1-..."
# Must be a VISION-capable model. Qwen3-VL slugs (cheapest → flagship):
#   qwen/qwen3-vl-8b-instruct · qwen/qwen3-vl-30b-a3b-instruct (good value)
#   qwen/qwen3-vl-32b-instruct · qwen/qwen3-vl-235b-a22b-instruct
OPENAI_VISION_MODEL="qwen/qwen3-vl-30b-a3b-instruct"
# Text model for social captions/hashtags (Social Studio). Defaults to gpt-4o-mini.
OPENAI_TEXT_MODEL="gpt-4o-mini"
# Image generation model for the Social Studio. Requires org verification on the
# OpenAI dashboard. Cost ≈ $0.01–0.25/image depending on size + quality.
OPENAI_IMAGE_MODEL="gpt-image-1"
# Safety cap: max AI creatives generated per rolling 24h (controls spend).
SOCIAL_DAILY_LIMIT="50"

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
# Object storage for product images and videos (zero egress fees).
# 1. dash.cloudflare.com → R2 Object Storage → Create bucket → name it "y2kase-media"
# 2. Manage R2 API Tokens → Create token → Object Read & Write for that bucket
# 3. Copy the Account ID, Access Key ID, and Secret Access Key below.
# 4. Bucket settings → Public access → Enable → copy the pub-XXXX.r2.dev URL.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="y2kase-media"
# Public base URL for the bucket (no trailing slash).
# Use the r2.dev domain until you connect a custom domain.
R2_PUBLIC_URL=""

# ── Local Catalog ─────────────────────────────────────────────────────────────
# SQLite staging database built by the ingest pipeline (scripts/build-catalog.ts).
CATALOG_DB_PATH="./data/catalog.db"
# Root folder containing product image/video subfolders. Structure it as
#   <root>/<category>/<product-slug-or-sku>/{1.jpg,2.mp4,...}
# Optional sidecars (see catalog.config.example.json):
#   <root>/catalog.config.json            → per-category defaults (type, price…)
#   <root>/<category>/<product>/listing.json → per-product overrides
LOCAL_CATALOG_ROOT="./bestListings"
# How many products the bulk ingest processes in parallel. Higher = faster, but
# watch the vision provider's rate limits. Default 3. (1 = fully sequential.)
INGEST_CONCURRENCY="3"

# ── Store presentation ────────────────────────────────────────────────────────
NEXT_PUBLIC_STORE_CURRENCY="USD"

# ── Analytics — Google Analytics 4 ────────────────────────────────────────────
# GA4 Measurement ID (https://analytics.google.com → Admin → Data Streams → Web).
# When set, gtag.js loads and the full ecommerce funnel is tracked
# (view_item, add_to_cart, begin_checkout, purchase). Leave blank to disable.
NEXT_PUBLIC_GA_ID=""

# ── Analytics — Meta (Facebook) Pixel + Conversions API ───────────────────────
# Meta Pixel enables Facebook/Instagram remarketing and Shopping ads.
# Client-side Pixel ID: https://business.facebook.com → Events Manager → Pixels
# Leave blank to disable the Pixel entirely.
NEXT_PUBLIC_META_PIXEL_ID=""
# Server-side Conversions API access token (bypasses iOS 14 / ad blockers).
# Events Manager → your Pixel → Settings → Conversions API → Generate Access Token
META_CAPI_ACCESS_TOKEN=""
# Optional: set during development to route events to Meta's test event tool.
# Events Manager → Test Events → find the code (e.g. TEST12345). Remove in prod.
META_CAPI_TEST_CODE=""

# ── Analytics — TikTok Pixel ──────────────────────────────────────────────────
# TikTok Ads Manager → Library → Events → Web Events → Set Up Web Events → Pixel
# https://ads.tiktok.com/i18n/events_manager/pixel/list
# Leave blank to disable.
NEXT_PUBLIC_TIKTOK_PIXEL_ID=""

# ── Analytics — Pinterest Tag ─────────────────────────────────────────────────
# Required to run Pinterest Shopping Ads (Performance+ campaigns).
# https://ads.pinterest.com → Ads → Conversions → Connect your Pinterest tag
# Leave blank to disable.
NEXT_PUBLIC_PINTEREST_TAG_ID=""

# ── Pinterest publishing (Social Studio P3) ───────────────────────────────────
# Enables one-click + scheduled auto-publishing of AI creatives to Pinterest.
# 1. developers.pinterest.com → create an app (Standard access).
# 2. Generate an access token with scopes: boards:read, pins:read, pins:write.
# 3. Paste the token below. Leave blank to disable auto-publishing (the studio
#    still works for generation + manual download).
PINTEREST_ACCESS_TOKEN=""
# Optional: override the API base (defaults to https://api.pinterest.com/v5).
# PINTEREST_API_BASE="https://api.pinterest.com/v5"

# ── Pinterest auto-pin drip (autonomous catalog distribution) ─────────────────
# Posts the next un-pinned LISTING to Pinterest every day — every product photo
# as an image pin plus the product video as a video pin — recording each asset
# as pinned so the whole catalog goes out one listing at a time with no
# duplicates and zero manual work. Runs via /api/cron/pinterest-autopin.
# Opt-in: must be exactly "true" to run automatically.
PINTEREST_AUTOPIN_ENABLED="false"
# How many LISTINGS a single cron run posts. Keep at 1 so the day's volume is
# spread across the scheduled cron slots (vercel.json) rather than one burst.
PINTEREST_AUTOPIN_PER_RUN="1"
# Hard cap on LISTINGS posted per UTC day across ALL runs (each listing = all
# its photos + video, ~8-14 pins). The single knob for daily volume: 1 for a
# gentle drip, 2 (≈20-28 fresh pins/day) to accelerate coverage. To go higher,
# raise this AND add matching /api/cron/pinterest-autopin slots in vercel.json.
PINTEREST_AUTOPIN_PER_DAY="1"
# Pause between individual media posts, ms (stays under Pinterest write limits).
# PINTEREST_AUTOPIN_GAP_MS="1500"
# Board to pin to. Leave blank to use the account's first board.
# Find ids via the studio's board picker, or the boards:read API.
PINTEREST_AUTOPIN_BOARD_ID=""

# ── Meta content publishing — Instagram + Facebook (Social Studio) ────────────
# Auto-posts one listing/day to Instagram (carousel + Reel) and the Facebook
# Page (multi-photo post + video). Runs via /api/cron/meta-autopost.
#
# Setup (all required before it can post in production):
#   1. developers.facebook.com → create an app → add "Facebook Login" +
#      "Instagram" products.
#   2. Your Instagram must be a BUSINESS/CREATOR account linked to the FB Page.
#   3. Complete Business Verification + App Review for these permissions:
#      instagram_content_publish, pages_manage_posts, publish_video,
#      instagram_basic, pages_read_engagement, pages_show_list, business_management
#   4. Add the App ID/Secret below, then click "Connect" in /admin/social
#      (stores a non-expiring Page token in the DB — no refresh cron needed).
META_APP_ID=""
META_APP_SECRET=""
# Opt-in: must be exactly "true" to run the daily drip automatically.
META_AUTOPOST_ENABLED="false"
# How many listings to post per daily run (each → IG + FB).
META_AUTOPOST_PER_RUN="1"
# Optional tuning / overrides:
# META_AUTOPOST_GAP_MS="3000"
# META_AUTOPOST_MAX_ATTEMPTS="3"
# META_GRAPH_VERSION="v25.0"
# META_REDIRECT_URI="https://y2kase.com/api/auth/meta/callback"
# Pin a specific Page / IG account (otherwise the first managed Page is used).
# FACEBOOK_PAGE_ID=""
# INSTAGRAM_BUSINESS_ID=""

# ── Stripe ───────────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
# Use sk_test_ / pk_test_ keys for local development; sk_live_ / pk_live_ in prod.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Local dev: run `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# and copy the printed `whsec_...` value here. In prod, copy it from the
# Dashboard webhook endpoint you create for /api/webhooks/stripe.
STRIPE_WEBHOOK_SECRET=""

# ── Resend (transactional email) ──────────────────────────────────────────────
# https://resend.com/api-keys  — free tier: 3,000 emails/month
# Powers the order-confirmation email sent from the Stripe webhook.
RESEND_API_KEY=""
# Verified sender address. Until your domain is verified in Resend you can test
# with "Y2KASE <onboarding@resend.dev>".
EMAIL_FROM="Y2KASE <orders@y2kase.com>"

# ── Cron (abandoned-cart recovery) ────────────────────────────────────────────
# Secret that authorizes Vercel Cron calls to /api/cron/abandoned-cart.
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# Set the SAME value in Vercel project env — Vercel sends it as a Bearer token.
CRON_SECRET=""

# ── Admin Inbox (IMAP — hello@y2kase.com) ─────────────────────────────────────
# Enables the /admin/inbox page to read hello@y2kase.com via Namecheap Private Email.
# IMAP host for Namecheap Private Email (do not change unless you switch providers).
IMAP_HOST="mail.privateemail.com"
IMAP_PORT="993"
# Your full email address for the inbox you want to read.
IMAP_USER="hello@y2kase.com"
# The password for that email account (set in Namecheap Private Email / privateemail.com).
IMAP_PASS=""
