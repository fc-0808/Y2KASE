# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local catalog database (contains product data, keep out of git)
/data/

# Local-only ingest assets — NOT needed by the deployed app (it reads from
# Neon + Cloudflare R2). Keep these multi-GB folders out of the repo.
/bestListings/
# Raw brand reference drop — the app uses the copies in public/brand/ instead.
/images/
# Local product image library (multi-GB source photos used only for catalog
# ingest). The deployed app serves images from R2, never from this folder.
/Products/

# Cursor MCP — .cursor/mcp.json is safe to commit: it holds remote OAuth URLs
# (stripe, vercel) and the local `resend` stdio server, whose API key is loaded
# at runtime from .env.local via the `envFile` field — NO secret lives in the file.
# NEVER hardcode live keys (sk_live_ / rk_live_ / re_...) in .cursor/mcp.json.
# If you need a local key override, put it in .cursor/mcp.local.json (gitignored below)
.cursor/mcp.local.json
